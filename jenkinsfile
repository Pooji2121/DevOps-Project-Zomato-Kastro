pipeline {
    agent any

    tools {
        jdk 'jdk17'
        nodejs 'node23'
    }

    environment {
        SCANNER_HOME = tool 'sonar-scanner'
    }

    stages {
        stage('Clean Workspace') {
            steps {
                cleanWs()
            }
        }

        stage('Git Checkout') {
            steps {
                git 'https://github.com/Pooji2121/zomato-clone-app-deployment.git'
            }
        }

        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('sonar-server') {
                    sh '''
                        $SCANNER_HOME/bin/sonar-scanner \
                        -Dsonar.projectName=zomato-app \
                        -Dsonar.projectKey=zomato-app
                    '''
                }
            }
        }

        stage('Quality Gate') {
            steps {
                script {
                    waitForQualityGate abortPipeline: false
                }
            }
        }

        stage('Install Dependencies') {
            steps {
                sh 'npm install'
            }
        }

        stage('Security Scan (Trivy)') {
            steps {
                sh 'trivy fs . > trivy-report.txt'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t pooji09/zomato-app .'
            }
        }

        stage('Push to DockerHub') {
            steps {
                script {
                    withDockerRegistry(credentialsId: 'docker') {
                        sh 'docker push pooji09/zomato-app:latest'
                    }
                }
            }
        }

        stage('Docker Scout Analysis') {
            steps {
                sh 'docker scout quickview pooji09/zomato-app:latest || true'
                sh 'docker scout cves pooji09/zomato-app:latest || true'
                sh 'docker scout recommendations pooji09/zomato-app:latest || true'
            }
        }

        stage('Deploy Container') {
            steps {
                sh '''
                    docker rm -f zomato-app || true
                    docker run -d --name zomato-app -p 3000:3000 pooji09/zomato-app:latest
                '''
            }
        }
    }

    post {
        always {
            emailext attachLog: true,
                subject: "Build Status: ${currentBuild.result}",
                body: """
                    <html>
                    <body>
                        <h3>DevOps Pipeline Notification</h3>
                        <p><b>Project:</b> ${env.JOB_NAME}</p>
                        <p><b>Build Number:</b> ${env.BUILD_NUMBER}</p>
                        <p><b>Build URL:</b> ${env.BUILD_URL}</p>
                    </body>
                    </html>
                """,
                to: 'poojinuthalapati09@gmail.com',
                mimeType: 'text/html',
                attachmentsPattern: 'trivy-report.txt'
        }
    }
}
